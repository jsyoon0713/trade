# LS증권 OpenAPI 키 (https://openapi.ls-sec.co.kr 에서 발급)
LS_APP_KEY=your_app_key_here
LS_APP_SECRET=your_app_secret_here

# 계좌 정보
LS_ACCOUNT_NO=12345678   # 8자리 계좌번호
LS_ACCOUNT_PWD=0000       # 계좌 비밀번호

# 모의투자 여부 (true=모의투자, false=실거래)
LS_IS_PAPER=true

# ── 웹 대시보드 ──
# 포트 (기본 5001, 다른 서비스와 충돌 시 변경)
WEB_PORT=5001

# 로그인 인증 (외부 접속 시 반드시 설정, 비워두면 인증 없음)
WEB_USERNAME=admin
WEB_PASSWORD=your_secure_password_here

# Flask 세션 암호화 키 (랜덤 문자열로 변경 권장)
FLASK_SECRET_KEY=change-this-to-random-string
